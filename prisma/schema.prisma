generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model address {
  id         String   @id @default(uuid())
  userId     String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model contactmessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model coupon {
  id            String    @id @default(uuid())
  code          String    @unique(map: "Coupon_code_key")
  description   String?
  discountType  String    @default("PERCENT")
  discountValue Float
  minOrderValue Float     @default(0)
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model customeractivity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model order {
  id              String       @id @default(uuid())
  userId          String
  totalAmount     Float
  status          order_status @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  stripeSessionId String?      @unique(map: "Order_stripeSessionId_key")
  courierName     String?
  refundAmount    Float?
  refundId        String?
  trackingNumber  String?
  isSuspect       Boolean      @default(false)
  user            user         @relation(fields: [userId], references: [id])
  orderitem       orderitem[]
  orderlog        orderlog[]

  @@index([userId])
}

model orderitem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  priceAtBuy Float
  order      order   @relation(fields: [orderId], references: [id])
  product    product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model orderlog {
  id        String          @id @default(uuid())
  orderId   String
  status    orderlog_status
  changedBy String
  message   String?
  createdAt DateTime        @default(now())
  order     order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model product {
  id                String      @id @default(uuid())
  name              String
  description       String
  price             Float
  brand             String?
  category          String
  imageUrls         String
  stock             Int         @default(0)
  lowStockThreshold Int         @default(5)
  isFeatured        Boolean     @default(false)
  slug              String?     @unique(map: "Product_slug_key")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderitem         orderitem[]
  review            review[]
  wishlist          wishlist[]
}

model review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  title     String?
  comment   String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([userId])
}

model session {
  id           String   @id @default(uuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user {
  id                String              @id @default(uuid())
  name              String?
  email             String?             @unique(map: "User_email_key")
  emailVerified     DateTime?
  password          String?
  image             String?
  role              user_role           @default(USER)
  marketingOptIn    Boolean             @default(false)
  mfaEnabled        Boolean             @default(false)
  mfaSecret         String?             // Encrypted TOTP secret
  failedLoginCount  Int                 @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  account           account[]
  address           address[]
  customeractivity  customeractivity[]
  order             order[]
  review            review[]
  session           session[]
  useravatar        useravatar?
  wishlist          wishlist[]
  behavioralevent   behavioralevent[]
  auditlog          auditlog[]
  devicefingerprint devicefingerprint[]
  mfabackupcode     mfabackupcode[]
}

model useravatar {
  id        String   @id @default(uuid())
  userId    String   @unique(map: "UserAvatar_userId_key")
  modelURL  String?
  bodyType  String   @default("ATHLETIC")
  skinTone  String   @default("#E0AC69")
  height    Float    @default(1.8)
  weight    Float    @default(75)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token])
}

model wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model newslettersubscriber {
  id        String   @id @default(uuid())
  email     String   @unique(map: "NewsletterSubscriber_email_key")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model behavioralevent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String   // "AI_STYLIST_QUERY", "SHOWROOM_INTERACTION", "RUNWAY_VIEW", "CHECKOUT_CONVERSION"
  metadata  Json?
  createdAt DateTime @default(now())
  user      user?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
}

enum orderlog_status {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
  PROCESSING
  REFUNDED
}

enum order_status {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
  PROCESSING
  REFUNDED
}

enum user_role {
  GUEST
  USER
  SELLER
  ADMIN
  SUPER_ADMIN
}

// ── MODULE 3: Shield Layer ─────────────────────────────────

/// Immutable audit log — INSERT-only by application design.
/// Records every security-relevant action in the system.
/// No UPDATE or DELETE operations should ever be performed on this table.
model auditlog {
  id                String   @id @default(uuid())
  userId            String?
  action            String   // LOGIN, LOGOUT, LOGIN_FAILED, PASSWORD_CHANGE, ORDER_PLACED, ADMIN_ACTION, MFA_ENABLED, etc.
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  metadata          Json?    // Arbitrary JSON: { reason, targetUserId, orderId, etc. }
  severity          String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt         DateTime @default(now())
  user              user?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}

/// Known devices per user — for detecting new/unknown login sources.
model devicefingerprint {
  id             String   @id @default(uuid())
  userId         String
  fingerprintHash String  // SHA-256 hash of device attributes
  deviceName     String?  // "Chrome on Windows 10", "Safari on iPhone 15"
  ipAddress      String?
  city           String?
  country        String?
  isTrusted      Boolean  @default(false) // User has confirmed this device
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  user           user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprintHash])
  @@index([userId])
}

/// MFA backup codes — one-time use recovery codes, bcrypt-hashed.
model mfabackupcode {
  id        String   @id @default(uuid())
  userId    String
  codeHash  String   // bcrypt hash of the backup code
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
